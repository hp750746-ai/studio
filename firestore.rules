rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Support both paths used in the app
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /doctors/{docId} { allow read: if isSignedIn(); }
    match /medicines/{medId} { allow read: if isSignedIn(); }
    match /labTests/{testId} { allow read: if isSignedIn(); }
    match /timeSlots/{slotId} { allow read, write: if isSignedIn(); }
  }
}